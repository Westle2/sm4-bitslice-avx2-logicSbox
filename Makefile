#==========================================================
# File: Makefile
# Project: SM4 High Performance Study
# Supports:
#   Linux (gcc / clang)
#   MinGW (Windows)
#
# Build:
#   make
#   make run
#   make clean
#==========================================================

# ---------------------------------------------------------
# Compiler
# ---------------------------------------------------------
CC      := gcc

# ---------------------------------------------------------
# Directories
# ---------------------------------------------------------
SRC_DIR := src
INC_DIR := include
BIN_DIR := bin

# ---------------------------------------------------------
# Target
# ---------------------------------------------------------
TARGET  := $(BIN_DIR)/sm4_demo

# ---------------------------------------------------------
# Source Files
# ---------------------------------------------------------
SRC = \
$(SRC_DIR)/main.c \
$(SRC_DIR)/benchmark.c \
$(SRC_DIR)/sm4_basic.c \
$(SRC_DIR)/sm4_avx2.c \
$(SRC_DIR)/sm4_bitslice.c

# ---------------------------------------------------------
# Object Files
# ---------------------------------------------------------
OBJ = $(SRC:.c=.o)

# ---------------------------------------------------------
# Flags
# ---------------------------------------------------------
CFLAGS = -O3 -Wall -Wextra -std=c11 -I$(INC_DIR)

# AVX2 Optimization
CFLAGS += -mavx2 -maes -march=native

# Optional aggressive tuning
# CFLAGS += -funroll-loops -flto

# ---------------------------------------------------------
# OS detect
# ---------------------------------------------------------
ifeq ($(OS),Windows_NT)
TARGET := $(BIN_DIR)/sm4_demo.exe
endif

# ---------------------------------------------------------
# Default
# ---------------------------------------------------------
all: prep $(TARGET)

# ---------------------------------------------------------
# Create bin/
# ---------------------------------------------------------
prep:
	@mkdir -p $(BIN_DIR)

# ---------------------------------------------------------
# Link
# ---------------------------------------------------------
$(TARGET): $(OBJ)
	$(CC) $(OBJ) -o $(TARGET)

# ---------------------------------------------------------
# Compile
# ---------------------------------------------------------
$(SRC_DIR)/%.o: $(SRC_DIR)/%.c
	$(CC) $(CFLAGS) -c $< -o $@

# ---------------------------------------------------------
# Run
# ---------------------------------------------------------
run: all
	./$(TARGET)

# ---------------------------------------------------------
# Clean
# ---------------------------------------------------------
clean:
	rm -f $(SRC_DIR)/*.o
	rm -f $(TARGET)

# ---------------------------------------------------------
# Rebuild
# ---------------------------------------------------------
rebuild: clean all

# ---------------------------------------------------------
# Benchmark Only
# ---------------------------------------------------------
bench: all
	./$(TARGET)

# ---------------------------------------------------------
# Help
# ---------------------------------------------------------
help:
	@echo "Usage:"
	@echo "  make         Build project"
	@echo "  make run     Build and run"
	@echo "  make clean   Remove objects"
	@echo "  make rebuild Clean then build"
